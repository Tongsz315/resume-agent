#### 🔹 动效设计（Framer Motion实现）
```tsx
// 示例：结果卡片入场动画
import { motion, useAnimation } from 'framer-motion';

const ResultCard = ({ analysis }) => {
  const controls = useAnimation();
  
  // 滚动到可视区域时触发动画
  useInView(controls, { once: true });
  
  return (
    <motion.div
      initial={{ opacity: 0, y: 20 }}
      animate={controls.start({ opacity: 1, y: 0 })}
      transition={{ duration: 0.4, ease: "easeOut" }}
      className="card-shadow rounded-xl bg-surface-1 p-6"
    >
      {/* 内容 */}
    </motion.div>
  );
};

// 流式输出打字机效果
const TypewriterText = ({ text }) => (
  <motion.span
    initial={{ width: 0 }}
    animate={{ width: "100%" }}
    transition={{ duration: text.length * 0.02, ease: "linear" }}
    className="inline-block overflow-hidden whitespace-nowrap"
  >
    {text}
    <motion.span
      animate={{ opacity: [1, 0] }}
      transition={{ repeat: Infinity, duration: 0.8 }}
      className="inline-block w-0.5 h-4 ml-0.5 bg-primary-500"
    />
  </motion.span>
);
```

